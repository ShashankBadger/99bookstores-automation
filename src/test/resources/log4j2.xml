<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="INFO">
    <Appenders>

        <!-- Console Logging -->
        <Console name="ConsoleAppender" target="SYSTEM_OUT">
            <PatternLayout pattern="%d{yyyy-MM-dd HH:mm:ss.SSS} [%t] %-5level %logger{36} - %msg%n"/>
        </Console>

        <!-- File Logging -->
        <File name="FileAppender" fileName="logs/application.log"> 

            <PatternLayout pattern="%d{yyyy-MM-dd HH:mm:ss.SSS} [%t] %-5level %logger{36} - %msg%n"/> 

        </File>
        
        <RollingFile name="RollingFileAppender" fileName="logs/daily-logs/automation.log" filePattern="logs/daily-logs/automation-%d{yyyy-MM-dd}-%i.log.gz"> 
            <PatternLayout pattern="%d{yyyy-MM-dd HH:mm:ss.SSS} [%t] %-5level %logger{36} - %msg%n"/> 
            <Policies> 
                <TimeBasedTriggeringPolicy/> <SizeBasedTriggeringPolicy size="10MB"/> </Policies> 
            <DefaultRolloverStrategy max="5"/> </RollingFile>
    </Appenders>

    <Loggers>
    <Logger name="base" level="info" additivity="false">
        <AppenderRef ref="ConsoleAppender"/>
        <AppenderRef ref="FileAppender"/>
        <AppenderRef ref="RollingFileAppender"/>
    </Logger>

    <Logger name="tests" level="info" additivity="false">
        <AppenderRef ref="ConsoleAppender"/>
        <AppenderRef ref="FileAppender"/>
        <AppenderRef ref="RollingFileAppender"/>
    </Logger>

    <!-- SUPPRESS SELENIUM NOISE -->
    <Logger name="org.openqa.selenium" level="warn"/>
    <Logger name="org.testng" level="warn"/>
    <Logger name="org.apache" level="warn"/>

    <Root level="info">
        <AppenderRef ref="ConsoleAppender"/>
        <AppenderRef ref="FileAppender"/>
        <AppenderRef ref="RollingFileAppender"/>
    </Root>

	</Loggers>

</Configuration>